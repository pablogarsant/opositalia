# Variables de entorno de PRODUCCIÓN (Vercel → Settings → Environment Variables)
# Mismas claves que .env.local con estos cambios:
#  - NEXT_PUBLIC_APP_URL apunta al dominio de producción
#  - Clerk: la instancia development (pk_test/sk_test) funciona en *.vercel.app;
#    la instancia Production de Clerk requiere dominio propio con DNS (no *.vercel.app)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/registro
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# Anthropic (chat + generación de sesiones + burocracia)
ANTHROPIC_API_KEY=

# OpenAI (embeddings RAG)
OPENAI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=https://opositalia.vercel.app
